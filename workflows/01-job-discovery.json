      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO job_postings (company_name, role_title, job_description, required_skills, experience_required, apply_link, posted_date, source, location, salary_info)\nVALUES ($1, $2, $3, $4::jsonb, $5, $6, $7::timestamptz, $8, $9, $10)\nON CONFLICT (company_name, role_title, apply_link) DO NOTHING\nRETURNING id",
        "additionalFields": {
          "queryParams": "={{ JSON.stringify([\n  $('Split Per Job').item.json.company_name,\n  $('Split Per Job').item.json.role_title,\n  $('Split Per Job').item.json.job_description,\n  $('Split Per Job').item.json.required_skills,\n  $('Split Per Job').item.json.experience_required,\n  $('Split Per Job').item.json.apply_link,\n  $('Split Per Job').item.json.posted_date,\n  $('Split Per Job').item.json.source,\n  $('Split Per Job').item.json.location,\n  $('Split Per Job').item.json.salary_info\n]) }}"
        }
