            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Parse Jobs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse and normalize JSearch API response\nconst response = $input.item.json;\nconst jobs = response.data || [];\n\nconst results = [];\n\nfor (const job of jobs) {\n  // Skip jobs without apply link\n  if (!job.job_apply_link && !job.job_google_link) continue;\n\n  const applyLink = job.job_apply_link || job.job_google_link || '';\n  const companyName = (job.employer_name || '').trim();\n  const roleTitle = (job.job_title || '').trim();\n\n  if (!companyName || !roleTitle) continue;\n\n  // Parse salary info\n  let salaryInfo = '';\n  if (job.job_min_salary && job.job_max_salary) {\n    salaryInfo = `${job.job_salary_currency || 'INR'} ${job.job_min_salary}–${job.job_max_salary} ${job.job_salary_period || ''}`.trim();\n  }\n\n  // Extract required skills from highlights\n  const requiredSkills = [];\n  if (job.job_highlights && job.job_highlights.Qualifications) {\n    requiredSkills.push(...job.job_highlights.Qualifications.slice(0, 10));\n  }\n\n  results.push({\n    company_name: companyName,\n    role_title: roleTitle,\n    job_description: job.job_description || '',\n    required_skills: JSON.stringify(requiredSkills),\n    experience_required: job.job_required_experience\n      ? `${job.job_required_experience.required_experience_in_months || 0} months`\n      : '',\n    apply_link: applyLink,\n    posted_date: job.job_posted_at_datetime_utc || null,\n    source: 'jsearch',\n    location: [job.job_city, job.job_state, job.job_country].filter(Boolean).join(', '),\n    salary_info: salaryInfo\n  });\n}\n\nif (results.length === 0) {\n  // Return empty marker to avoid downstream errors\n  return [{ json: { _empty: true, total: 0 } }];\n}\n\nreturn results.map(j => ({ json: j }));\n"
      }
    },
    {
      "id": "a1b2c3d4-0006-4000-8000-000000000006",
