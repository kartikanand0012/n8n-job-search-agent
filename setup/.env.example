# =============================================================================
# Job Search Agent - Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=job_agent
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=your_password_here

# -----------------------------------------------------------------------------
# APIs
# -----------------------------------------------------------------------------
# RapidAPI key for JSearch (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI API (platform.openai.com → API Keys)
OPENAI_API_KEY=your_openai_key_here

# -----------------------------------------------------------------------------
# Telegram Notifications
# -----------------------------------------------------------------------------
# Create bot via @BotFather on Telegram, get token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Get your chat_id: message @userinfobot or check getUpdates response
TELEGRAM_CHAT_ID=your_chat_id

# -----------------------------------------------------------------------------
# Email (Gmail)
# -----------------------------------------------------------------------------
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=kartikanand0012@gmail.com

# Use App Password (not your main Gmail password)
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_PASSWORD=your_app_password

# Gmail OAuth2 credentials (for Workflow 06 HTTP approach)
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# -----------------------------------------------------------------------------
# n8n Configuration
# -----------------------------------------------------------------------------
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http

# Set to your public URL if behind a proxy (e.g., https://n8n.yourdomain.com)
WEBHOOK_URL=http://localhost:5678

# n8n encryption key (generate: openssl rand -hex 24)
N8N_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Basic auth for n8n UI (recommended)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password

# -----------------------------------------------------------------------------
# Resume Paths
# -----------------------------------------------------------------------------
# Plain text base resume that AI will tailor
BASE_RESUME_PATH=/home/ubuntu/resumes/base_resume.txt

# Directory where tailored resumes will be saved
RESUME_OUTPUT_DIR=/home/ubuntu/resumes/tailored/

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
# Minimum skill match score (0-100) to trigger notifications and resume generation
MATCH_THRESHOLD=70

# Comma-separated job search keywords (used in Workflow 01)
JOB_SEARCH_KEYWORDS=Software Engineer,SRE,Backend Developer,Product Analyst,Full Stack Developer

# OpenAI model to use (gpt-4o-mini is cost-efficient)
OPENAI_MODEL=gpt-4o-mini

# Max tokens for JD processing
OPENAI_MAX_TOKENS=2000
